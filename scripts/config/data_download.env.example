# Copy to data_download.env and edit:
#   cp scripts/config/data_download.env.example scripts/config/data_download.env
#
# Must match setup_path.py DATA_PATH prefix + dataset path fragments in yaml (e.g. mnt/DATA/...).
export DATA_ROOT="${DATA_ROOT:-$HOME}"

# --- Pick ONE transport (or run multiple times with different settings) ---

# Google Cloud Storage: sync a prefix into DATA_ROOT (requires gcloud + gsutil)
export GCS_SYNC_URI="${GCS_SYNC_URI:-}"
# Example: gs://your-bucket/brca_full/

# HTTP(S): download a single file (requires curl or wget)
export DATA_URL="${DATA_URL:-}"
export DATA_DEST="${DATA_DEST:-$DATA_ROOT/mnt/DATA/brca_full/cancer_cells_only.h5ad}"

# Local rsync from another mount (e.g. shared NFS)
export RSYNC_SRC="${RSYNC_SRC:-}"
