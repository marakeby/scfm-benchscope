# Copy to model_weights.env and edit (or export vars before running download_model_weights.sh):
#   cp scripts/config/model_weights.env.example scripts/config/model_weights.env
#
# Root directory for checkpoints (match embedding.params.model_dir / dict_dir in your YAML).
export MODEL_ROOT="${MODEL_ROOT:-$HOME/mnt/MODELS}"

# Geneformer: pip-installable code lives under third_party/Geneformer (see install_packages.sh).
# Weights + token dictionaries are large — fetched here (git lfs pull or hf download).

# Set to 1 to pull Git LFS objects in third_party/Geneformer (after skip-smudge clone).
export PULL_GENEFORMER_LFS="${PULL_GENEFORMER_LFS:-0}"

# Hugging Face snapshot for a specific checkpoint (optional; requires: pixi run -e default pip install huggingface_hub hf_transfer)
# Example: Geneformer V2 104M weights into MODEL_ROOT
export HF_DOWNLOAD_GENEFORMER_V2_104M="${HF_DOWNLOAD_GENEFORMER_V2_104M:-0}"
export HF_REPO_GENEFORMER_V2_104M="${HF_REPO_GENEFORMER_V2_104M:-ctheodoris/Geneformer-V2-104M}"

# Token / gene dictionaries (match yaml dict_dir, e.g. gf_dicts_v2)
export DICT_DEST="${DICT_DEST:-$HOME/mnt/gf_dicts_v2}"
export HF_DOWNLOAD_GENEFORMER_DICTS="${HF_DOWNLOAD_GENEFORMER_DICTS:-0}"
# If dicts are hosted as a separate HF dataset/repo, set ID:
export HF_REPO_GENEFORMER_DICTS="${HF_REPO_GENEFORMER_DICTS:-}"

# Optional Hugging Face token for gated models
# export HF_TOKEN=""
