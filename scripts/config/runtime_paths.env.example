# Paths read by setup_path.py (data, outputs, models, optional YAML root).
# Copy and edit, then source the loader script:
#   cp scripts/config/runtime_paths.env.example scripts/config/runtime_paths.env
#   source scripts/set_runtime_paths.sh
#
# Or point the loader at your file:
#   SCFM_RUNTIME_CONFIG=/path/to/my.env source scripts/set_runtime_paths.sh

export SCFM_DATA_PATH="$HOME/mnt/DATA"
export SCFM_OUTPUT_PATH="$HOME/mnt/__output_v7"
export SCFM_MODELS_PATH="$HOME/mnt/MODELS"
# Optional: directory containing your experiment YAML tree (default = bundled package yaml/).
# export SCFM_PARAMS_PATH="$HOME/projects/my_study/yaml"
